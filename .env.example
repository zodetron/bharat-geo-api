# ============================================================
# Bharat Geo API — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (NeonDB or any PostgreSQL) ─────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET="your-long-random-secret-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── Redis (Upstash) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── CORS (comma-separated list of allowed frontend origins)
# Leave unset for local dev (defaults to localhost ports)
# CORS_ORIGINS="https://admin.yourdomain.com,https://portal.yourdomain.com,https://demo.yourdomain.com"

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
